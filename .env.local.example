# Mapbox GL public token for the /map view (required to render the map).
# Free token (pk....) at https://account.mapbox.com/access-tokens/ — must be NEXT_PUBLIC_.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: Upstash Redis for caching live API responses
# (postcodes.io, Overpass, police.uk, Land Registry).
#
# The app works fully WITHOUT these — caching is simply skipped when unset.
# Failed or partial upstream responses are never cached.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── ETL pipelines (pipelines/) ──────────────────────────────────────────────
# Postgres + PostGIS (Supabase) connection used by the Python ETL pipelines.
#   local PostGIS:  postgresql://postgres:postgres@localhost:55432/areaiq
#   Supabase:       postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=

# MHCLG "Get energy performance of buildings data" API - Bearer token (free; register on the service
# and copy the token from your account page). Used by the app's EPC property check (src/lib/epc.ts).
# Server-only - never exposed to the browser. The old epc.opendatacommunities.org API was retired May 2026.
EPC_API_KEY=
